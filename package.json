{
  "name": "relay",
  "version": "0.1.0",
  "productName": "Relay",
  "description": "macOS IDE pairing git worktrees with Claude Code",
  "main": "out/main/index.js",
  "scripts": {
    "start": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "build:icons": "mkdir -p build/icon.iconset && for size in 16 32 64 128 256 512; do sips -z $size $size assets/icon.png --out build/icon.iconset/icon_${size}x${size}.png > /dev/null && sips -z $((size*2)) $((size*2)) assets/icon.png --out build/icon.iconset/icon_${size}x${size}@2x.png > /dev/null; done && iconutil -c icns build/icon.iconset -o build/icon.icns",
    "package": "npm run build:icons && electron-vite build && electron-builder --mac",
    "postinstall": "electron-rebuild -f -w node-pty"
  },
  "build": {
    "appId": "com.relay.app",
    "productName": "Relay",
    "directories": {
      "buildResources": "build",
      "output": "dist"
    },
    "mac": {
      "target": "dmg",
      "category": "public.app-category.developer-tools"
    },
    "files": [
      "out/**/*",
      "assets/**/*"
    ]
  },
  "dependencies": {
    "@babel/runtime": "^7.29.2",
    "@codemirror/commands": "^6.10.3",
    "@codemirror/lang-cpp": "^6.0.3",
    "@codemirror/lang-css": "^6.3.1",
    "@codemirror/lang-html": "^6.4.11",
    "@codemirror/lang-java": "^6.0.2",
    "@codemirror/lang-javascript": "^6.2.5",
    "@codemirror/lang-json": "^6.0.2",
    "@codemirror/lang-markdown": "^6.5.0",
    "@codemirror/lang-python": "^6.2.1",
    "@codemirror/lang-rust": "^6.0.2",
    "@codemirror/language": "^6.12.3",
    "@codemirror/legacy-modes": "^6.5.2",
    "@codemirror/state": "^6.6.0",
    "@codemirror/theme-one-dark": "^6.1.3",
    "@codemirror/view": "^6.40.0",
    "@uiw/codemirror-theme-dracula": "^4.25.9",
    "@uiw/codemirror-theme-github": "^4.25.9",
    "@uiw/codemirror-theme-monokai": "^4.25.9",
    "@uiw/codemirror-theme-nord": "^4.25.9",
    "@uiw/codemirror-theme-solarized": "^4.25.9",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/xterm": "^6.0.0",
    "diff2html": "^3.4.56",
    "electron-store": "^11.0.2",
    "highlight.js": "^11.11.1",
    "lucide-react": "^1.7.0",
    "node-pty": "^1.1.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.0.3",
    "@tailwindcss/vite": "^4.2.2",
    "@types/node": "^22.0.0",
    "@types/react": "^18.0.0",
    "@types/react-dom": "^18.0.0",
    "@vitejs/plugin-react": "^4.0.0",
    "electron": "^39.8.4",
    "electron-builder": "^26.8.1",
    "electron-vite": "^3.1.0",
    "tailwindcss": "^4.2.2",
    "typescript": "^5.5.0"
  }
}
